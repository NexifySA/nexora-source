# =============================================================================
# Nexify Social — Producción
# Copiar a .env.nexify.production y reemplazar todos los CHANGE_ME_*
# Generar secretos: openssl rand -hex 32
# =============================================================================

# ---------- URLs públicas ----------
# Cambiar por tu dominio cuando apuntes DNS:
# MAIN_URL=https://nexpost.com.ar
# FRONTEND_URL=https://nexpost.com.ar
# NEXT_PUBLIC_BACKEND_URL=https://nexpost.com.ar/api
# Por ahora apunta a la IP del droplet para testing:
MAIN_URL=http://45.55.55.148
FRONTEND_URL=http://45.55.55.148
NEXT_PUBLIC_BACKEND_URL=http://45.55.55.148/api

# URL interna (la app se habla a sí misma dentro del contenedor)
BACKEND_INTERNAL_URL=http://localhost:3000

# ---------- Base de datos ----------
POSTGRES_USER=nexify_postiz
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL
POSTGRES_DB=nexify_postiz

# ---------- Redis ----------
# (sin password porque sólo es accesible en la red interna; si se expone, agregar AUTH)

# ---------- Temporal ----------
TEMPORAL_DB_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL

# ---------- Seguridad ----------
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
# openssl rand -hex 32

# ---------- Flags ----------
IS_GENERAL=true
DISABLE_REGISTRATION=false
NOT_SECURED=true
# ^ Dejar NOT_SECURED=true mientras estés en HTTP. Al activar HTTPS con Nginx+certbot, borrar esta variable.

# ---------- Storage ----------
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads
# Alternativa R2/Cloudflare (comentar local y descomentar):
# STORAGE_PROVIDER=cloudflare
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ACCESS_KEY=
# CLOUDFLARE_SECRET_ACCESS_KEY=
# CLOUDFLARE_BUCKETNAME=
# CLOUDFLARE_BUCKET_URL=
# CLOUDFLARE_REGION=auto

# ---------- Branding visible (OAuth generic — opcional) ----------
# NEXT_PUBLIC_POSTIZ_OAUTH_DISPLAY_NAME=Nexify Social
# NEXT_PUBLIC_POSTIZ_OAUTH_LOGO_URL=https://nexpost.com.ar/logo.svg

# ---------- Social providers (OAuth de plataforma) ----------
# IMPORTANTE: estas credenciales son GLOBALES de Nexpost, NO por usuario.
# El operador (vos) crea UNA app OAuth por red en el portal del provider y pega
# client_id/secret acá. Cada usuario final que se loguea en Nexpost puede entonces
# conectar su propia cuenta de la red usando esta app compartida.
# Matriz completa con callback URLs y portales: docs/03-security/OAUTH_ENV_MATRIX_NEXPOST.md
# Dejar vacío al inicio; cualquier provider con CLIENT_ID vacío tira:
#   "You need to pass the \"client_id\" parameter"

X_API_KEY=
X_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
GOOGLE_GMB_CLIENT_ID=
GOOGLE_GMB_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN_ID=
SLACK_ID=
SLACK_SECRET=
SLACK_SIGNING_SECRET=
MASTODON_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=
BEEHIIVE_API_KEY=
BEEHIIVE_PUBLICATION_ID=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
KICK_CLIENT_ID=
KICK_SECRET=
VK_ID=
WHOP_CLIENT_ID=
TELEGRAM_TOKEN=
NEYNAR_CLIENT_ID=
NEYNAR_SECRET_KEY=
MEWE_API_KEY=
MEWE_APP_ID=
MEWE_HOST=

# ---------- AI / Misc ----------
OPENAI_API_KEY=
API_LIMIT=30
NEXT_PUBLIC_DISCORD_SUPPORT=
NEXT_PUBLIC_POLOTNO=

# ---------- Pagos (opcional — sólo si vas a vender suscripciones) ----------
# FEE_AMOUNT=0.05
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_SIGNING_KEY=
# STRIPE_SIGNING_KEY_CONNECT=

# ---------- SMTP (opcional, necesario para activaciones/reset) ----------
# EMAIL_PROVIDER=nodemailer
# EMAIL_FROM_ADDRESS=no-reply@nexify.com.ar
# EMAIL_FROM_NAME=Nexify Social
# EMAIL_HOST=smtp.tu-proveedor.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=
# EMAIL_PASS=

# ---------- Next.js internals ----------
NX_ADD_PLUGINS=false
